        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    class Usuario {\n        +UUID id\n        +String nome\n        +String email\n        +String senhaHash\n        +String role\n        +String status\n    }\n\n    class Cliente {\n        +comprar()\n        +avaliar()\n    }\n\n    class Vendedor {\n        +String cnpj\n        +String nomeLoja\n        +String status\n        +gerenciarProdutos()\n        +solicitarSaque()\n    }\n\n    class Produto {\n        +UUID id\n        +String nome\n        +String descricao\n        +Decimal preco\n        +Integer estoque\n        +String status\n    }\n\n    class Categoria {\n        +UUID id\n        +String nome\n        +String slug\n    }\n\n    class Carrinho {\n        +UUID id\n        +Decimal total\n    }\n\n    class ItemCarrinho {\n        +Integer quantidade\n        +Decimal precoUnitario\n    }\n\n    class Pedido {\n        +UUID id\n        +String numero\n        +String status\n        +Decimal total\n    }\n\n    class ItemPedido {\n        +Integer quantidade\n        +Decimal precoUnitario\n    }\n\n    class Pagamento {\n        +UUID id\n        +String metodo\n        +String status\n        +Decimal valor\n        +String gatewayReference\n    }\n\n    class Carteira {\n        +UUID id\n        +Decimal saldo\n        +Decimal saldoPendente\n    }\n\n    class MovimentacaoCarteira {\n        +UUID id\n        +String tipo\n        +Decimal valor\n        +String descricao\n    }\n\n    class Saque {\n        +UUID id\n        +Decimal valor\n        +String status\n    }\n\n    class Plano {\n        +UUID id\n        +String nome\n        +Decimal mensalidade\n        +Decimal taxaComissao\n    }\n\n    class Assinatura {\n        +UUID id\n        +String status\n        +DateTime inicio\n        +DateTime fim\n    }\n\n    Usuario &lt;|-- Cliente\n    Usuario &lt;|-- Vendedor\n\n    Cliente \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Carrinho\n    Cliente \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Pedido\n\n    Vendedor \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Produto\n    Vendedor \&quot;1\&quot; --&gt; \&quot;1\&quot; Carteira\n    Vendedor \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Assinatura\n\n    Categoria \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Produto\n\n    Carrinho \&quot;1\&quot; --&gt; \&quot;1..*\&quot; ItemCarrinho\n    ItemCarrinho \&quot;*\&quot; --&gt; \&quot;1\&quot; Produto\n\n    Pedido \&quot;1\&quot; --&gt; \&quot;1..*\&quot; ItemPedido\n    ItemPedido \&quot;*\&quot; --&gt; \&quot;1\&quot; Produto\n\n    Pedido \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Pagamento\n    Pedido \&quot;*\&quot; --&gt; \&quot;1\&quot; Vendedor\n\n    Carteira \&quot;1\&quot; --&gt; \&quot;0..*\&quot; MovimentacaoCarteira\n    Carteira \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Saque\n\n    Plano \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Assinatura&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="cI2x5KAg-N-DMzlwpddO-1">
